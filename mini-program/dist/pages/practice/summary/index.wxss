.practice-summary-page{padding-bottom:64rpx}.summary-card{padding:30rpx;text-align:center}.summary-check{align-items:center;background:#0f4f3f;border-radius:50%;display:flex;height:88rpx;justify-content:center;margin:0 auto 18rpx;width:88rpx}.summary-check-text{color:#fff;font-size:46rpx;line-height:54rpx}.summary-title{color:#111827;display:block;font-size:32rpx;font-weight:800;line-height:42rpx;margin-bottom:20rpx}.summary-metrics{display:grid;gap:12rpx;grid-template-columns:repeat(3,minmax(0,1fr))}.summary-question-list{display:flex;flex-direction:column;gap:16rpx}.summary-question-card{padding:22rpx}.summary-question-header{align-items:center;display:flex;gap:14rpx;margin-bottom:16rpx}.summary-checkbox{align-items:center;background:#fff;border:2rpx solid #e8e2d8;border-radius:10rpx;display:flex;height:42rpx;justify-content:center;width:42rpx}.summary-checkbox-selected{background:#0f4f3f;border-color:#0f4f3f}.summary-checkbox-mark{color:#fff;font-size:24rpx;font-weight:700;line-height:30rpx}.summary-question-title{color:#111827;flex:1;font-size:28rpx;font-weight:700;line-height:38rpx}.advice-card{background:#eaf6f1;display:flex;gap:18rpx;padding:24rpx}.advice-icon{align-items:center;background:#0f4f3f;border-radius:50%;color:#fff;display:flex;font-size:28rpx;font-weight:800;height:48rpx;justify-content:center;line-height:36rpx;width:48rpx}.advice-copy{flex:1}.advice-title{color:#0f4f3f;display:block;font-size:28rpx;font-weight:700;line-height:38rpx}.advice-text{color:#111827;display:block;font-size:24rpx;line-height:36rpx;margin-top:8rpx}.summary-actions{display:flex;flex-direction:column;gap:16rpx}.summary-home-link{color:#0f4f3f;display:block;font-size:26rpx;line-height:36rpx;padding:12rpx 0;text-align:center}