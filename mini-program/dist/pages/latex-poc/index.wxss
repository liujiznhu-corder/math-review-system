.latex-poc-page{background:#f7f4ee;box-sizing:border-box;color:#111827;min-height:100vh;padding:32rpx 24rpx 48rpx}.latex-poc-header{display:flex;flex-direction:column;gap:10rpx;margin-bottom:24rpx}.latex-poc-title{color:#0f4f3f;font-size:34rpx;font-weight:700;line-height:44rpx}.latex-poc-subtitle{color:#6b7280;font-size:24rpx;line-height:34rpx}.latex-poc-note{background:#eaf6f1;border:1rpx solid #d8e8df;border-radius:16rpx;color:#0f4f3f;font-size:24rpx;line-height:34rpx;margin-bottom:24rpx;padding:20rpx}.latex-poc-filters{display:flex;flex-direction:row;flex-wrap:wrap;gap:12rpx;margin-bottom:20rpx}.latex-poc-filter{background:#fff;border:1rpx solid #d8e8df;border-radius:999rpx;color:#4b635b;font-size:22rpx;line-height:30rpx;padding:8rpx 16rpx}.latex-poc-filter-active{background:#0f4f3f;border-color:#0f4f3f;color:#fff}.latex-poc-count{color:#6b7280;display:block;font-size:22rpx;line-height:30rpx;margin-bottom:18rpx}