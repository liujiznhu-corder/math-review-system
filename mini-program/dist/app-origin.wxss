page{background:#f7f4ee;color:#111827;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;min-height:100%}button,image,input,page,scroll-view,swiper,swiper-item,text,textarea,view{box-sizing:border-box}.page-shell{background:#f7f4ee;min-height:100vh;padding:28rpx 24rpx 48rpx}.page-stack{display:flex;flex-direction:column;gap:24rpx}.section-title-row{align-items:center;display:flex;justify-content:space-between;margin-bottom:16rpx}.section-title{color:#111827;font-size:30rpx;font-weight:700;line-height:40rpx}.section-action{color:#0f4f3f;font-size:24rpx;line-height:34rpx}.learning-page{padding-bottom:150rpx}.progress-summary{display:flex;flex-direction:column;gap:14rpx}.progress-summary-row{align-items:center;display:flex;justify-content:space-between}.progress-summary-title{color:#111827;font-size:26rpx;font-weight:700;line-height:34rpx}.progress-summary-percent{color:#0f4f3f;font-size:24rpx;line-height:32rpx}.question-card{padding:26rpx}.question-card-header{align-items:center;display:flex;gap:14rpx;justify-content:space-between;margin-bottom:22rpx}.question-card-tags{display:flex;flex-wrap:wrap;gap:10rpx}.question-title{color:#111827;display:block;font-size:30rpx;font-weight:700;line-height:40rpx;margin-bottom:16rpx}.question-copy{color:#111827;display:block;font-size:26rpx;line-height:40rpx;margin-bottom:18rpx}.answer-link{align-items:center;background:#eef3ff;border-radius:14rpx;display:flex;justify-content:center;margin-top:22rpx;min-height:76rpx}.answer-link-text{color:#3159a6;font-size:26rpx;font-weight:700;line-height:34rpx}.bottom-action-bar{background:hsla(40,36%,95%,.96);border-top:1rpx solid #e8e2d8;bottom:0;display:grid;gap:18rpx;grid-template-columns:repeat(2,minmax(0,1fr));left:0;padding:20rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));position:fixed;right:0}.bottom-action-bar-single{grid-template-columns:1fr}.completion-card{padding:34rpx 28rpx;text-align:center}.completion-title{color:#0f4f3f;display:block;font-size:34rpx;font-weight:800;line-height:44rpx}.completion-copy{color:#6b7280;display:block;font-size:24rpx;line-height:36rpx;margin-top:12rpx}